@model EmployeeManagementSystem.Data.Models.Employee

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-zinc-100 py-12 px-6 font-sans">

    <div class="max-w-2xl mx-auto">

        <!-- Back Button -->
        <a asp-action="Index"
           class="inline-flex items-center gap-2 text-indigo-600 hover:text-indigo-700 mb-8 font-medium transition-colors">
            ← Back to Employee List
        </a>

        <!-- Main Card -->
        <div class="bg-white rounded-3xl shadow-2xl shadow-slate-300/60 overflow-hidden">

            <!-- Header -->
            <div class="px-10 pt-10 pb-6 border-b border-gray-100">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 bg-gradient-to-br from-indigo-600 to-blue-600 rounded-2xl flex items-center justify-center text-white text-4xl shadow-inner">
                        ✏️
                    </div>
                    <div>
                        <h1 class="text-3xl font-semibold tracking-tight text-gray-900">Edit Employee</h1>
                        <p class="text-gray-500 mt-1">Update employee information</p>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="p-10 space-y-8">

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="CreatedAt" />
                <input type="hidden" asp-for="IsActive" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                    <!-- Employee Code -->
                    <div>
                        <label asp-for="EmployeeCode" class="block text-sm font-medium text-gray-700 mb-2"></label>
                        <input asp-for="EmployeeCode"
                               class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all text-base"
                               placeholder="EMP-001" />
                        <span asp-validation-for="EmployeeCode" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <!-- Department -->
                    <div>
                        <label asp-for="Department" class="block text-sm font-medium text-gray-700 mb-2"></label>
                        <input asp-for="Department"
                               class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all text-base"
                               placeholder="HR / IT / Finance" />
                        <span asp-validation-for="Department" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <!-- Designation -->
                    <div class="md:col-span-2">
                        <label asp-for="Designation" class="block text-sm font-medium text-gray-700 mb-2"></label>
                        <input asp-for="Designation"
                               class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all text-base"
                               placeholder="Software Engineer / Manager" />
                        <span asp-validation-for="Designation" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <!-- Phone -->
                    <div>
                        <label asp-for="Phone" class="block text-sm font-medium text-gray-700 mb-2"></label>
                        <input asp-for="Phone" type="tel"
                               class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all text-base"
                               placeholder="+91 98765 43210" />
                        <span asp-validation-for="Phone" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <!-- Salary -->
                    <div>
                        <label asp-for="Salary" class="block text-sm font-medium text-gray-700 mb-2"></label>
                        <div class="relative">
                            <span class="absolute left-5 top-1/2 -translate-y-1/2 text-gray-500 font-medium">₹</span>
                            <input asp-for="Salary" type="number" step="0.01"
                                   class="w-full pl-12 pr-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all text-base"
                                   placeholder="75000" />
                        </div>
                        <span asp-validation-for="Salary" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <!-- Date of Joining -->
                    <div class="md:col-span-2">
                        <label asp-for="DateOfJoining" class="block text-sm font-medium text-gray-700 mb-2"></label>
                        <input asp-for="DateOfJoining" type="date"
                               class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-2xl focus:outline-none focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all text-base" />
                        <span asp-validation-for="DateOfJoining" class="text-red-500 text-xs mt-1"></span>
                    </div>

                </div>

                <!-- Action Buttons -->
                <div class="flex gap-4 pt-6 border-t border-gray-100">
                    <a asp-action="Index"
                       class="flex-1 py-4 text-center border border-gray-300 hover:border-gray-400 rounded-2xl font-medium text-gray-700 transition-all active:scale-95">
                        Cancel
                    </a>

                    <button type="submit"
                            class="flex-1 py-4 bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 text-white font-semibold rounded-2xl transition-all active:scale-95 shadow-lg shadow-indigo-500/30">
                        Update Employee
                    </button>
                </div>
            </form>
        </div>

        <!-- Footer Note -->
        <p class="text-center text-xs text-gray-400 mt-8">
            Changes will be saved securely • Employee Management System
        </p>
    </div>
</div>