@model EmployeeManagementSystem.Modules.Employee.ViewModels.CreateEmployeeViewModel

<h2>Create Employee</h2>

<form asp-action="Create" method="post">

    <div>
        <label>User Id</label>
        <input asp-for="UserId" />
    </div>

    <div>
        <label>Employee Code</label>
        <input asp-for="EmployeeCode" />
    </div>

    <div>
        <label>Department</label>
        <input asp-for="Department" />
    </div>

    <div>
        <label>Designation</label>
        <input asp-for="Designation" />
    </div>

    <div>
        <label>Phone</label>
        <input asp-for="Phone" />
    </div>

    <div>
        <label>Salary</label>
        <input asp-for="Salary" />
    </div>

    <div>
        <label>Date Of Joining</label>
        <input asp-for="DateOfJoining" type="date" />
    </div>

    <button type="submit">Create Employee</button>

</form>