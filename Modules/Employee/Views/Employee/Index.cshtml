@{
    Layout = "_Layout";
}

@model List<EmployeeManagementSystem.Data.Models.Employee>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Employees</h3>
        <a asp-action="Create" class="btn btn-primary">+ Add Employee</a>
    </div>

    <table class="table table-striped table-bordered shadow">
        <thead class="table-dark">
            <tr>
                <th>Code</th>
                <th>Department</th>
                <th>Designation</th>
                <th>Phone</th>
                <th width="220px">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.EmployeeCode</td>
                    <td>@emp.Department</td>
                    <td>@emp.Designation</td>
                    <td>@emp.Phone</td>

                    <td>
                        <a asp-action="Details" asp-route-id="@emp.Id" class="btn btn-info btn-sm">View</a>

                        <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-warning btn-sm">Edit</a>

                        <a asp-action="Delete" asp-route-id="@emp.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>