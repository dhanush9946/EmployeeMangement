@model List<EmployeeManagementSystem.Data.Models.Employee>

<h2>Employees</h2>

<a asp-action="Create">Add Employee</a>

<table border="1">
    <thead>
        <tr>
            <th>Code</th>
            <th>Department</th>
            <th>Designation</th>
            <th>Phone</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.EmployeeCode</td>
                <td>@emp.Department</td>
                <td>@emp.Designation</td>
                <td>@emp.Phone</td>
                <td>
                   <a asp-action="Details" asp-route-id="@emp.Id">Details</a>

                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@emp.Id">Edit</a>
                </td>
                <td>
                    <a asp-action="Delete" asp-route-id="@emp.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>