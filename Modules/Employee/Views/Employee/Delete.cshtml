@model EmployeeManagementSystem.Data.Models.Employee

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-gradient-to-br from-slate-50 to-zinc-100 py-12 px-6 font-sans">

    <div class="max-w-lg mx-auto">

        <!-- Main Card -->
        <div class="bg-white rounded-3xl shadow-2xl shadow-red-100/70 overflow-hidden">

            <!-- Warning Header -->
            <div class="bg-red-50 px-10 py-8 flex flex-col items-center text-center border-b border-red-100">
                <div class="w-20 h-20 bg-red-100 text-red-600 rounded-3xl flex items-center justify-center text-5xl mb-6">
                    ⚠️
                </div>
                <h2 class="text-3xl font-semibold text-red-800 tracking-tight">Delete Employee</h2>
                <p class="text-red-600 mt-3 text-lg">This action cannot be undone.</p>
            </div>

            <!-- Employee Information -->
            <div class="p-10">

                <div class="bg-zinc-50 rounded-2xl p-6 mb-8 border border-zinc-100">
                    <h4 class="text-sm font-medium text-gray-500 mb-4 tracking-widest">EMPLOYEE TO BE DELETED</h4>

                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600">Employee Code</span>
                            <span class="font-semibold text-gray-900">@Model.EmployeeCode</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600">Department</span>
                            <span class="font-semibold text-gray-900">@Model.Department</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-600">Designation</span>
                            <span class="font-semibold text-gray-900">@Model.Designation</span>
                        </div>
                    </div>
                </div>

                <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 text-amber-800 text-sm mb-8">
                    <strong class="block mb-1">Warning:</strong>
                    Deleting this employee will permanently remove all associated records.
                    This action is irreversible.
                </div>

                <!-- Form -->
                <form asp-action="DeleteConfirmed" method="post" class="space-y-6">

                    <input type="hidden" asp-for="Id" />

                    <!-- Action Buttons -->
                    <div class="flex flex-col sm:flex-row gap-4">

                        <a asp-action="Index"
                           class="flex-1 py-4 text-center border border-gray-300 hover:border-gray-400 font-medium text-gray-700 rounded-2xl transition-all active:scale-95">
                            Cancel
                        </a>

                        <button type="submit"
                                onclick="return confirm('Are you absolutely sure? This cannot be undone.')"
                                class="flex-1 py-4 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-semibold rounded-2xl transition-all active:scale-95 shadow-lg shadow-red-500/30 flex items-center justify-center gap-2">
                            <span>Yes, Delete Employee</span>
                            <span class="text-xl">→</span>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Footer -->
            <div class="bg-gray-50 px-10 py-6 text-center text-xs text-gray-500 border-t">
                Employee Management System • Action is permanent
            </div>
        </div>
    </div>
</div>