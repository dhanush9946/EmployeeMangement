@model EmployeeManagementSystem.Modules.Auth.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee Management System</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        .glass {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-600 via-indigo-600 to-purple-700 min-h-screen flex items-center justify-center font-sans">

    <div class="max-w-md w-full mx-auto px-6 py-8">
        <!-- Card -->
        <div class="glass rounded-3xl shadow-2xl overflow-hidden border border-white/20">

            <!-- Header -->
            <div class="bg-white px-8 pt-8 pb-6 text-center">
                <div class="mx-auto w-20 h-20 bg-indigo-600 rounded-2xl flex items-center justify-center mb-4 shadow-inner">
                    <i class="fas fa-briefcase text-white text-4xl"></i>
                </div>
                <h1 class="text-3xl font-bold text-gray-900">Welcome Back</h1>
                <p class="text-gray-600 mt-2">Sign in to access your employee portal</p>
            </div>

            <!-- Form Content -->
            <div class="px-8 pb-8 pt-2">
                <form asp-controller="Auth" asp-action="Login" method="post" class="space-y-6">

                    @if (ViewBag.Error != null)
                    {
                        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-lg text-red-700 text-sm">
                            <i class="fas fa-exclamation-circle mr-2"></i>
                            @ViewBag.Error
                        </div>
                    }

                    <!-- Email -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-gray-400"></i>
                            </div>
                            <input asp-for="Email"
                                   class="w-full pl-11 pr-4 py-3 border border-gray-300 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all outline-none text-gray-900"
                                   placeholder="you@company.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <!-- Password -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400"></i>
                            </div>
                            <input asp-for="Password" type="password"
                                   class="w-full pl-11 pr-4 py-3 border border-gray-300 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all outline-none text-gray-900"
                                   placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <!-- Submit Button -->
                    <button type="submit"
                            class="w-full bg-indigo-600 hover:bg-indigo-700 active:bg-indigo-800 transition-all text-white font-semibold py-3.5 rounded-2xl text-base shadow-lg shadow-indigo-500/30 flex items-center justify-center gap-2">
                        <i class="fas fa-sign-in-alt"></i>
                        Sign In
                    </button>

                </form>

                <!-- Footer Links -->
                <div class="text-center mt-6 text-sm text-gray-600">
                    <p>
                        Don't have an account?
                        <a asp-controller="Auth" asp-action="Register"
                           class="text-indigo-600 hover:text-indigo-700 font-medium">Create Account</a>
                    </p>
                </div>
            </div>
        </div>

        <!-- Subtle Footer -->
        <div class="text-center text-white/70 text-xs mt-8">
            © 2026 Employee Management System
        </div>
    </div>

    <!-- Tailwind Script -->
    <script>
        tailwind.config = {
            content: [],
            theme: {
                extend: {}
            }
        }
    </script>
</body>
</html>