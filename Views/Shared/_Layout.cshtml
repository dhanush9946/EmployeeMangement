<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMS</title>

    <!-- ✅ Use ONLY ONE Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <div class="d-flex flex-column min-vh-100">

        <!-- 🔥 NAVBAR -->
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
                <div class="container">
                    <a class="navbar-brand" asp-controller="Employee" asp-action="Index">EMS</a>

                    <div class="navbar-nav">
                        <a class="nav-link" asp-controller="Employee" asp-action="Index">Employees</a>
                        <a class="nav-link" asp-controller="Employee" asp-action="Create">Add Employee</a>
                    </div>
                </div>
            </nav>
        </header>

        <!-- 🔥 MAIN CONTENT -->
        <main class="flex-fill container mt-4">
            @RenderBody()
        </main>

        <!-- 🔥 FOOTER -->
        <footer class="bg-light text-center p-3 mt-auto">
            © 2026 - Employee Management System
        </footer>

    </div>

    <!-- ✅ Scripts (ONLY ONE jQuery) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Validation -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>